# Public site URL — used for canonical/OG/sitemap/robots. MUST be set at BUILD
# time for Docker (NEXT_PUBLIC_* is inlined into the bundle), not just runtime.
NEXT_PUBLIC_SITE_URL=https://subhashai.cloud

# Public site/brand name.
NEXT_PUBLIC_SITE_NAME=subhashai.cloud

# Server-only: path to the Chromium binary used by the resume-PDF route.
# Set automatically in the Docker image; only needed for custom hosts.
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser
